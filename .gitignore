# --- Secretos: NUNCA commitear ---
.env
.env.*
!.env.example

# --- Datos (crudos y limpios) y base SQLite ---
# (data/* en vez de data/ para poder re-incluir archivos puntuales: git no
#  permite negar dentro de un directorio excluido como directorio)
data/*
# Excepcion: la metadata de procedencia del snapshot SI se versiona (ADR 0009).
!data/snapshot_meta.json
# Excepcion: la capa manual verificada (top-15) SI se versiona: es producto, no dato crudo.
!data/radar_manual.csv
*.db
*.sqlite
*.sqlite3
# Excepcion: el snapshot del dataset SI se versiona, para que el deploy
# (Streamlit Cloud) tenga datos. Son 259 jugadores, datos publicos, sin secretos.
!db/scout.db

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipynb_checkpoints/

# --- Caché de tooling / tests ---
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Streamlit ---
.streamlit/secrets.toml

# --- SO / editores ---
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
